{
  "name": "diagram-drc",
  "version": "0.1.0",
  "description": "Design Rule Check engine for auto-generated diagrams",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./rules": {
      "types": "./dist/rules/index.d.ts",
      "import": "./dist/rules/index.js"
    },
    "./layout": {
      "types": "./dist/layout/index.d.ts",
      "import": "./dist/layout/index.js"
    },
    "./render": {
      "types": "./dist/render/index.d.ts",
      "import": "./dist/render/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/de-otio/diagram-drc.git"
  },
  "keywords": [
    "diagram",
    "drc",
    "layout",
    "drawio",
    "mxgraph",
    "dagre",
    "graph",
    "design-rule-check"
  ],
  "author": "de-otio",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/de-otio/diagram-drc/issues"
  },
  "homepage": "https://github.com/de-otio/diagram-drc#readme",
  "dependencies": {
    "@dagrejs/dagre": "^1.1.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
